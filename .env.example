# Football Analytics — Environment Variables Template
# Copy this to .env and fill in your keys. Never commit .env.

# football-data.org — free API key from https://www.football-data.org/client/register
FOOTBALL_DATA_ORG_KEY=your_key_here

# API-Football via RapidAPI — https://rapidapi.com/api-sports/api/api-football
API_FOOTBALL_KEY=your_rapidapi_key_here
